# ===========================================
# MatchPredict 环境变量配置
# 复制此文件为 .env 并填入你的密钥
# ===========================================

# DeepSeek API (可选，如使用 Claude Code 推理则不需要)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# football-data.org API (可选，增强实时数据)
# 免费注册: https://www.football-data.org/client/register
FOOTBALL_DATA_KEY=your_football_data_key_here
